rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function adminEmails() {
      return ["adrian.arab@hotmail.de"];
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.admin == true
          || request.auth.token.email in adminEmails()
          || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        );
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userProfileFields() {
      return ['email', 'lastLoginAt', 'updatedAt'];
    }

    function hasTeamAccess(targetUserId) {
      return signedIn()
        && exists(/databases/$(database)/documents/teamAccess/$(request.auth.uid + "_" + targetUserId));
    }

    // Admin marker documents. Create these manually/server-side for trusted users.
    match /admins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // =========================
    // WORKOUTS
    // =========================
    match /workouts/{workoutId} {
      allow create: if isOwner(request.resource.data.userId);

      allow read: if isOwner(resource.data.userId) || isAdmin() || hasTeamAccess(resource.data.userId);

      allow update: if (isOwner(resource.data.userId) || isAdmin())
                    && request.resource.data.userId == resource.data.userId;

      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // =========================
    // PUSH TOKENS
    // =========================
    match /pushTokens/{tokenId} {
      allow create: if isOwner(request.resource.data.userId);

      allow read, delete: if isOwner(resource.data.userId) || isAdmin();

      allow update: if (isOwner(resource.data.userId) || isAdmin())
                    && request.resource.data.userId == resource.data.userId;
    }

    // =========================
    // USERS
    // =========================
    match /users/{userId} {
      // Team metadata is stored on users/{uid}. A user may read another
      // user's team data only as an admin or through an explicit
      // teamAccess/{currentUid}_{targetUid} grant.
      // Writes to teamIds remain admin-only below.
      allow read: if isOwner(userId) || isAdmin() || hasTeamAccess(userId);

      allow create: if isAdmin()
                    || (
                      isOwner(userId)
                      && request.resource.data.keys().hasOnly(userProfileFields())
                    );

      allow update: if isAdmin()
                    || (
                      isOwner(userId)
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(userProfileFields())
                    );

      allow delete: if isAdmin();
    }


    // =========================
    // TEAM ACCESS
    // =========================
    match /teamAccess/{accessId} {
      allow read: if isAdmin()
                  || (signedIn() && resource.data.viewerId == request.auth.uid);

      allow create, update: if isAdmin()
                            && request.resource.data.keys().hasOnly(['viewerId', 'targetUserId', 'teamId', 'createdAt'])
                            && accessId == request.resource.data.viewerId + "_" + request.resource.data.targetUserId
                            && request.resource.data.viewerId != request.resource.data.targetUserId;

      allow delete: if isAdmin();
    }

    // =========================
    // TEAMS
    // =========================
    match /teams/{teamId} {
      allow read: if signedIn();

      allow create: if isAdmin()
                    && request.resource.data.ownerId == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    // =========================
    // CHALLENGES
    // =========================
    match /challenges/{challengeId} {
      allow read: if signedIn();

      allow create: if signedIn()
                    && request.resource.data.createdBy == request.auth.uid;

      allow update, delete: if isAdmin()
                            || isOwner(resource.data.createdBy);
    }

    // =========================
    // ADMIN BEREICH
    // =========================
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
