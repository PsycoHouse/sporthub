rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userProfileFields() {
      return ['email', 'lastLoginAt', 'updatedAt'];
    }

    function hasStoredTeamIds(userId) {
      return exists(/databases/$(database)/documents/users/$(userId))
        && get(/databases/$(database)/documents/users/$(userId)).data.keys().hasAll(['teamIds']);
    }

    function hasSharedTeam() {
      return signedIn()
        && resource.data.keys().hasAll(['teamIds'])
        && hasStoredTeamIds(request.auth.uid)
        && resource.data.teamIds.hasAny(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamIds);
    }

    // Admin marker documents. Create these manually/server-side for trusted users.
    match /admins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // =========================
    // WORKOUTS
    // =========================
    match /workouts/{workoutId} {
      allow create: if isOwner(request.resource.data.userId);

      allow read: if isOwner(resource.data.userId) || isAdmin() || hasSharedTeam();

      allow update: if (isOwner(resource.data.userId) || isAdmin())
                    && request.resource.data.userId == resource.data.userId;

      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // =========================
    // PUSH TOKENS
    // =========================
    match /pushTokens/{tokenId} {
      allow create: if isOwner(request.resource.data.userId);

      allow read, delete: if isOwner(resource.data.userId) || isAdmin();

      allow update: if (isOwner(resource.data.userId) || isAdmin())
                    && request.resource.data.userId == resource.data.userId;
    }

    // =========================
    // USERS
    // =========================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isAdmin()
                    || (
                      isOwner(userId)
                      && request.resource.data.keys().hasOnly(userProfileFields())
                    );

      allow update: if isAdmin()
                    || (
                      isOwner(userId)
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(userProfileFields())
                    );

      allow delete: if isAdmin();
    }

    // =========================
    // TEAMS
    // =========================
    match /teams/{teamId} {
      allow read: if signedIn();

      allow create: if isAdmin()
                    && request.resource.data.ownerId == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    // =========================
    // CHALLENGES
    // =========================
    match /challenges/{challengeId} {
      allow read: if signedIn();

      allow create: if signedIn()
                    && request.resource.data.createdBy == request.auth.uid;

      allow update, delete: if isAdmin()
                            || isOwner(resource.data.createdBy);
    }

    // =========================
    // ADMIN BEREICH
    // =========================
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
